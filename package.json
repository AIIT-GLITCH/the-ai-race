{
  "name": "the-ai-race-orbit",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A twelve-lab anti-gravity sprint to the first orbital AI data center.",
  "license": "MIT",
  "scripts": {
    "build": "node scripts/build.mjs",
    "start": "node server.js",
    "check": "node --check server.js && node --input-type=module --check < game.js && node scripts/check.js && node scripts/race-control-check.mjs",
    "test:browser": "node scripts/browser-smoke.mjs",
    "test:options": "node scripts/gameplay-options-smoke.mjs",
    "test:graphics": "node scripts/graphics-smoke.mjs",
    "test:mobile": "node scripts/mobile-smoke.mjs",
    "test:showdown": "node scripts/showdown-smoke.mjs",
    "test:music": "node scripts/music-smoke.mjs"
  },
  "devDependencies": {
    "playwright-core": "^1.61.1"
  },
  "engines": {
    "node": ">=18"
  }
}
